<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF1EF"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".ui.MainActivity">

    <LinearLayout
        android:id="@+id/view_mode_switch"
        android:layout_width="148dp"
        android:layout_height="40dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/bg_mode_switch"
        android:elevation="2dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/card_mode"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mode_selected"
            android:gravity="center"
            android:text="卡片"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/list_mode"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="列表"
            android:textColor="@color/stellog_muted"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/page_indicator"
        android:layout_width="92dp"
        android:layout_height="40dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="18dp"
        android:background="@drawable/bg_page_pill"
        android:elevation="2dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/page_indicator_text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="1 / 3"
            android:textColor="#AEB4B1"
            android:textSize="17sp" />

        <TextView
            android:layout_width="30dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="≡"
            android:textColor="#AEB4B1"
            android:textSize="21sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/side_rail"
        android:layout_width="58dp"
        android:layout_height="82dp"
        android:background="@drawable/bg_side_rail"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/habit_pager">

        <ImageView
            android:id="@+id/reminder_button"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:contentDescription="提醒"
            android:gravity="center"
            android:padding="7dp"
            android:src="@drawable/ic_bell" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/habit_pager"
        android:layout_width="0dp"
        android:layout_height="500dp"
        android:layout_marginTop="56dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/view_mode_switch" />

    <ScrollView
        android:id="@+id/calendar_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="22dp"
        android:paddingTop="28dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="42dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:text="日历"
                    android:textColor="@color/stellog_ink"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/calendar_activity_filter_button"
                    android:layout_width="172dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_calendar_activity_filter"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="18dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:id="@+id/calendar_activity_filter_label"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="全部活动"
                        android:textColor="@color/stellog_ink"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="22dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="⌄"
                        android:textColor="@color/stellog_muted"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/calendar_prev_month"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:text="‹"
                        android:textColor="@color/stellog_muted"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/calendar_month_title"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textColor="@color/stellog_ink"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        tools:text="2026 年 5 月" />

                    <TextView
                        android:id="@+id/calendar_next_month"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:text="›"
                        android:textColor="@color/stellog_muted"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="一" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="二" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="三" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="四" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="五" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="六" />

                    <TextView
                        style="@style/CalendarWeekLabel"
                        android:text="日" />
                </LinearLayout>

                <android.widget.GridLayout
                    android:id="@+id/calendar_grid"
                    android:layout_width="match_parent"
                    android:layout_height="264dp"
                    android:alignmentMode="alignBounds"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:columnCount="7"
                    android:rowCount="6"
                    android:useDefaultMargins="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_calendar_panel"
                android:elevation="3dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/calendar_selected_date_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="5 月 12 日"
                    android:textColor="@color/stellog_ink"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/calendar_selected_records"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/calendar_completed_count"
                        style="@style/CalendarStatValue"
                        android:text="1" />

                    <TextView
                        android:id="@+id/calendar_plan_count"
                        style="@style/CalendarStatValue"
                        android:text="2" />

                    <TextView
                        android:id="@+id/calendar_completion_rate"
                        style="@style/CalendarStatValue"
                        android:text="50%" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <TextView
                        style="@style/CalendarStatLabel"
                        android:text="已完成" />

                    <TextView
                        style="@style/CalendarStatLabel"
                        android:text="计划数" />

                    <TextView
                        style="@style/CalendarStatLabel"
                        android:text="完成率" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_tabs"
        android:layout_width="0dp"
        android:layout_height="86dp"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/home_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="首页"
            android:textColor="@color/stellog_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/calendar_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="日历"
            android:textColor="#575D5A"
            android:textSize="18sp" />

        <Space
            android:layout_width="74dp"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/achievement_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="成就"
            android:textColor="#575D5A"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/profile_tab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="我的"
            android:textColor="#575D5A"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/add_activity_button"
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:background="@drawable/bg_add_fab"
        android:elevation="12dp"
        android:gravity="center"
        android:text="+"
        android:textColor="@color/white"
        android:textSize="38sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/bottom_tabs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/bottom_tabs" />

</androidx.constraintlayout.widget.ConstraintLayout>
