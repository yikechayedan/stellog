<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <LinearLayout
        android:id="@+id/habit_card_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_main_habit_card"
        android:elevation="3dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="28dp"
        android:paddingEnd="32dp"
        android:paddingBottom="22dp">

        <TextView
            android:id="@+id/habit_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:text="看书"
            android:textColor="@color/black"
            android:textSize="25sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="5dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:id="@+id/streak_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="0"
                android:textColor="@color/stellog_primary"
                android:textSize="60sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="天收获"
                android:textColor="@color/black"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/target_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="此日计 0 分钟，已累计 0 分钟"
                android:textColor="#939996"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/week_labels"
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                style="@style/WeekLabel"
                android:text="一"
                android:textColor="@color/stellog_primary" />

            <TextView
                style="@style/WeekLabel"
                android:text="二" />

            <TextView
                style="@style/WeekLabel"
                android:text="三" />

            <TextView
                style="@style/WeekLabel"
                android:text="四" />

            <TextView
                style="@style/WeekLabel"
                android:text="五" />

            <TextView
                style="@style/WeekLabel"
                android:text="六" />

            <TextView
                style="@style/WeekLabel"
                android:text="日" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/week_checks"
            android:layout_width="match_parent"
            android:layout_height="34dp"
            android:gravity="center"
            android:orientation="horizontal">

            <FrameLayout style="@style/WeekDotColumn">
                <TextView
                    android:id="@+id/week_dot_monday"
                    style="@style/WeekDot"
                    android:layout_gravity="center" />
            </FrameLayout>

            <FrameLayout style="@style/WeekDotColumn">
                <TextView
                    android:id="@+id/week_dot_tuesday"
                    style="@style/WeekDot"
                    android:layout_gravity="center" />
            </FrameLayout>

            <FrameLayout style="@style/WeekDotColumn">
                <TextView
                    android:id="@+id/week_dot_wednesday"
                    style="@style/WeekDot"
                    android:layout_gravity="center" />
            </FrameLayout>

            <FrameLayout style="@style/WeekDotColumn">
                <TextView
                    android:id="@+id/week_dot_thursday"
                    style="@style/WeekDot"
                    android:layout_gravity="center" />
            </FrameLayout>

            <FrameLayout style="@style/WeekDotColumn">
                <TextView
                    android:id="@+id/week_dot_friday"
                    style="@style/WeekDot"
                    android:layout_gravity="center" />
            </FrameLayout>

            <FrameLayout style="@style/WeekDotColumn">
                <TextView
                    android:id="@+id/week_dot_saturday"
                    style="@style/WeekDot"
                    android:layout_gravity="center" />
            </FrameLayout>

            <FrameLayout style="@style/WeekDotColumn">
                <TextView
                    android:id="@+id/week_dot_sunday"
                    style="@style/WeekDot"
                    android:layout_gravity="center" />
            </FrameLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#C9D0CC" />

        <TextView
            android:id="@+id/today_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="今天 | 2026-05-11"
            android:textColor="@color/stellog_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/check_in_button"
            android:layout_width="150dp"
            android:layout_height="46dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_check_in_button"
            android:elevation="2dp"
            android:gravity="center"
            android:text="打卡"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/checked_actions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="116dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="已收获"
                    android:textColor="#D5D8D6"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/record_detail_button"
                    android:layout_width="116dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="记录详细"
                    android:textColor="#8B918E"
                    android:textSize="18sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/cancel_check_in_button"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="取消"
                android:textColor="#C4C8C6"
                android:textSize="18sp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
