<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="44dp"
    android:clipChildren="false"
    android:clipToPadding="false">

    <TextView
        android:id="@+id/calendar_day_number"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textColor="@color/stellog_ink"
        android:textSize="16sp"
        android:textStyle="bold" />

    <View
        android:id="@+id/calendar_today_dot"
        android:layout_width="5dp"
        android:layout_height="5dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="5dp"
        android:background="@drawable/bg_calendar_today_dot"
        android:visibility="gone" />

    <TextView
        android:id="@+id/calendar_day_badge"
        android:layout_width="17dp"
        android:layout_height="17dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:background="@drawable/bg_calendar_count_badge"
        android:elevation="2dp"
        android:gravity="center"
        android:textColor="@color/stellog_primary"
        android:textSize="10sp"
        android:textStyle="bold"
        android:visibility="gone" />
</FrameLayout>
